"""Forward OOS 累计收益 + drawdown 曲线.

数据源: data_cache/portfolio.xlsx 'Forward OOS Track' (header=1).
< 3 月样本: fallback 显示 '积累中 X 月 / 3 月' 消息 (Lean 'Insufficient Data' 风格).
"""
from __future__ import annotations

from pathlib import Path

import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt
import pandas as pd

from dashboard.utils import fig_to_base64

MIN_MONTHS_FOR_CHART = 3
SHEET_NAME = "Forward OOS Track"


def _placeholder_html(message: str) -> str:
    """构造一个 fallback 的 HTML 块, 不画图."""
    return (
        '<div class="placeholder-content" style="padding:48px 16px;">'
        f"{message}"
        "</div>"
    )


def _load_forward_oos(portfolio_xlsx: Path) -> pd.DataFrame:
    """读 Forward OOS Track sheet, 返回 DataFrame (空表则返回空 DF)."""
    if not portfolio_xlsx.exists():
        return pd.DataFrame()
    try:
        df = pd.read_excel(portfolio_xlsx, sheet_name=SHEET_NAME, header=1)
    except Exception:
        return pd.DataFrame()
    if df.empty or "cum_return" not in df.columns:
        return pd.DataFrame()
    # 强类型 + 排序
    df = df.dropna(subset=["month_end_date", "cum_return"]).copy()
    df["month_end_date"] = pd.to_datetime(df["month_end_date"])
    df = df.sort_values("month_end_date").reset_index(drop=True)
    return df


def _build_drawdown(cum_return: pd.Series) -> pd.Series:
    """从累计收益序列 (decimal, e.g. -0.19) 计算 drawdown."""
    equity = 1.0 + cum_return
    peak = equity.cummax()
    dd = equity / peak - 1.0
    return dd


def build_forward_oos_chart(portfolio_xlsx: Path) -> str:
    """主入口: 返回可直接塞到 template `{{forward_oos_chart}}` 的 HTML 片段."""
    df = _load_forward_oos(portfolio_xlsx)
    n_months = len(df)

    if n_months == 0:
        return _placeholder_html(
            "Forward OOS Track 尚无数据 (portfolio.xlsx 该 sheet 为空).<br>"
            "需 paper_trade 累积至少 1 个完整月份后才会显示."
        )

    if n_months < MIN_MONTHS_FOR_CHART:
        latest = df.iloc[-1]
        cum_pct = latest["cum_return"] * 100
        return _placeholder_html(
            f"Forward OOS 积累中 — <b>{n_months} 月 / {MIN_MONTHS_FOR_CHART} 月</b><br>"
            f"当前累计收益: <b>{cum_pct:+.2f}%</b><br>"
            f"alert_level: <b>{latest.get('alert_level', 'n/a')}</b><br>"
            f"<span style='font-size:11px;'>"
            f"≥ {MIN_MONTHS_FOR_CHART} 月后将自动切换为 cumulative + drawdown 双子图."
            "</span>"
        )

    # 正常路径: 2 subplot
    fig, (ax1, ax2) = plt.subplots(
        2, 1, figsize=(10, 6), sharex=True,
        gridspec_kw={"height_ratios": [2, 1]},
    )

    cum = df["cum_return"]
    dates = df["month_end_date"]
    dd = _build_drawdown(cum)

    ax1.plot(dates, cum * 100, color="#2563eb", linewidth=2, marker="o")
    ax1.axhline(0, color="#9ca3af", linewidth=0.8, linestyle="--")
    ax1.fill_between(dates, cum * 100, 0,
                     where=(cum >= 0), color="#16a34a", alpha=0.15)
    ax1.fill_between(dates, cum * 100, 0,
                     where=(cum < 0), color="#dc2626", alpha=0.15)
    ax1.set_ylabel("Cumulative Return (%)")
    ax1.set_title(f"Forward OOS — {n_months} months", fontsize=12)
    ax1.grid(True, alpha=0.3)

    ax2.fill_between(dates, dd * 100, 0, color="#dc2626", alpha=0.5)
    ax2.plot(dates, dd * 100, color="#dc2626", linewidth=1.2)
    ax2.set_ylabel("Drawdown (%)")
    ax2.set_xlabel("Month End")
    ax2.grid(True, alpha=0.3)

    fig.autofmt_xdate()
    fig.tight_layout()

    uri = fig_to_base64(fig)
    plt.close(fig)
    return f'<img src="{uri}" alt="Forward OOS chart"/>'
